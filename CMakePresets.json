{
  "version": 6,
  "vendor": {
    "blu_os": {
      "autoFormat": true
    }
  },
  "configurePresets": [
    {
      "name": "default-i386",
      "displayName": "i386 32-bit Kernel",
      "description": "Build 32-bit x86 kernel with i386-elf toolchain",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/i386",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/i386-elf.cmake",
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      },
      "environment": {
        "NINJA_STATUS": "[%f/%t] "
      }
    },
    {
      "name": "default-x86_64",
      "displayName": "x86_64 64-bit Kernel",
      "description": "Build 64-bit x86 kernel with x86_64-elf toolchain",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/x86_64",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/amd64-elf.cmake",
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      },
      "environment": {
        "NINJA_STATUS": "[%f/%t] "
      }
    },
    {
      "name": "release-i386",
      "displayName": "i386 Release",
      "description": "Optimized 32-bit build",
      "inherits": "default-i386",
      "binaryDir": "${sourceDir}/build/i386-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "release-x86_64",
      "displayName": "x86_64 Release",
      "description": "Optimized 64-bit build",
      "inherits": "default-x86_64",
      "binaryDir": "${sourceDir}/build/x86_64-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "i386-debug",
      "configurePreset": "default-i386",
      "jobs": 0,
      "targets": ["blu_os.kernel32"]
    },
    {
      "name": "x86_64-debug",
      "configurePreset": "default-x86_64",
      "jobs": 0,
      "targets": ["blu_os.kernel64"]
    },
    {
      "name": "i386-release",
      "configurePreset": "release-i386",
      "jobs": 0,
      "targets": ["blu_os.kernel32"]
    },
    {
      "name": "x86_64-release",
      "configurePreset": "release-x86_64",
      "jobs": 0,
      "targets": ["blu_os.kernel64"]
    },
    {
      "name": "all-debug",
      "configurePreset": "default-i386",
      "jobs": 0
    }
  ],
  "testPresets": []
}